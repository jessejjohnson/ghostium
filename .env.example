# Optional overrides for scripts.

WORK_MOUNT=/work
CHROMIUM_ROOT=/work/chromium
SRC_DIR=/work/chromium/src
DEPOT_TOOLS_DIR=/work/depot_tools
DIST_ROOT=/work/dist
LOG_ROOT=/work/logs

# c7i.8xlarge default.
JOBS=24

# Swap size.
SWAP_SIZE=32G

# Optional explicit disk device for 01-init-instance.sh.
# WORK_DEVICE=/dev/nvme1n1

# Set to 0 if the volume is already formatted.
FORMAT_WORK_DEVICE=1
